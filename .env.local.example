# Credenciais S3 do bucket Supabase
# COPIA isso pra .env.local (sem .example) e preenche com os valores reais.
# .env.local está no .gitignore — NUNCA commita esses valores.

# Credenciais S3 — só pra rodar o script de upload local de vídeos
SUPABASE_S3_ENDPOINT=https://<project-id>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_BUCKET=designJane
